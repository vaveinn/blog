---
import demoAvatar from "@assets/images/demo-avatar.png";
import { friendSources } from "@/data/friends";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { resolveFriendLinks } from "@utils/friend-links";
import { Icon } from "astro-icon/components";

const friends = await resolveFriendLinks(friendSources, {
	fallbackAvatar: demoAvatar.src,
});
---

<MainGridLayout title="友链" description="友链页面">
	<section class="friend-wall card-base relative overflow-hidden">
		<div class="friend-panel relative z-10 px-6 py-7 md:px-10 md:py-9">
			<header class="mb-6 md:mb-8">
				<h1 class="flex items-center gap-3 text-90 text-3xl md:text-4xl font-bold mb-4">
					<span class="friend-title-icon">
						<Icon
							name="material-symbols:group-rounded"
							class="text-[1.8rem] text-black/80 dark:text-white/85"
						/>
					</span>
					友链
				</h1>
				<p class="text-75 text-base md:text-lg leading-8">
					在 <code>src/data/friends.ts</code> 添加网址即可自动读取网站图标和简介。
				</p>
			</header>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
				{
					friends.map((friend) => (
						<a
							href={friend.url}
							target="_blank"
							rel="noopener noreferrer"
							class="friend-card group rounded-2xl p-5 md:p-6 min-h-32"
						>
							<div class="flex items-start gap-4">
								<img
									src={friend.avatar}
									alt={`${friend.name} icon`}
									class="h-12 w-12 rounded-xl object-cover border friend-avatar-border"
									loading="lazy"
									referrerpolicy="no-referrer"
									onerror={`this.onerror=null;this.src='${demoAvatar.src}';`}
								/>
								<div class="min-w-0 flex-1">
									<h2 class="friend-title text-xl md:text-2xl mb-1 truncate">{friend.name}</h2>
									<p class="friend-description text-base leading-7 mb-2 line-clamp-2">
										{friend.description}
									</p>
									<p class="friend-url text-sm truncate">{friend.url}</p>
								</div>
								<Icon
									name="fa6-solid:arrow-up-right-from-square"
									class="friend-arrow mt-1 transition"
								/>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>
</MainGridLayout>

<style>
	.friend-wall {
		min-height: 32rem;
		background: var(--card-bg);
	}

	.friend-panel {
		background:
			radial-gradient(
				circle at 20% 10%,
				rgba(255, 255, 255, 0.28),
				rgba(255, 255, 255, 0) 42%
			),
			linear-gradient(145deg, rgba(255, 255, 255, 0.15), rgba(0, 0, 0, 0.06));
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.friend-title-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 3rem;
		width: 3rem;
		border-radius: 0.75rem;
		background: oklch(0.76 0.16 170);
		box-shadow: 0 8px 20px rgba(40, 170, 150, 0.35);
	}

	.friend-card {
		background: rgba(255, 255, 255, 0.38);
		border: 1px solid rgba(255, 255, 255, 0.36);
		backdrop-filter: blur(14px) saturate(1.1);
		-webkit-backdrop-filter: blur(14px) saturate(1.1);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background-color 180ms ease;
	}

	.friend-card:hover {
		transform: translateY(-2px);
		border-color: rgba(255, 255, 255, 0.68);
		background: rgba(255, 255, 255, 0.48);
	}

	.friend-title {
		color: rgba(0, 0, 0, 0.84);
		font-weight: 700;
	}

	.friend-description {
		color: rgba(0, 0, 0, 0.7);
	}

	.friend-url {
		color: rgba(0, 0, 0, 0.58);
	}

	.friend-arrow {
		color: rgba(0, 0, 0, 0.5);
	}

	.friend-card:hover .friend-arrow {
		color: rgba(0, 0, 0, 0.82);
	}

	.friend-avatar-border {
		border-color: rgba(0, 0, 0, 0.12);
	}

	:global(.dark) .friend-panel {
		background:
			radial-gradient(
				circle at 20% 10%,
				rgba(255, 255, 255, 0.06),
				rgba(255, 255, 255, 0) 42%
			),
			linear-gradient(145deg, rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0.2));
	}

	:global(.dark) .friend-card {
		background: rgba(18, 22, 30, 0.42);
		border-color: rgba(255, 255, 255, 0.18);
	}

	:global(.dark) .friend-card:hover {
		background: rgba(18, 22, 30, 0.56);
		border-color: rgba(255, 255, 255, 0.32);
	}

	:global(.dark) .friend-title {
		color: rgba(255, 255, 255, 0.92);
	}

	:global(.dark) .friend-description {
		color: rgba(255, 255, 255, 0.78);
	}

	:global(.dark) .friend-url {
		color: rgba(255, 255, 255, 0.62);
	}

	:global(.dark) .friend-arrow {
		color: rgba(255, 255, 255, 0.56);
	}

	:global(.dark) .friend-card:hover .friend-arrow {
		color: rgba(255, 255, 255, 0.9);
	}

	:global(.dark) .friend-avatar-border {
		border-color: rgba(255, 255, 255, 0.2);
	}
</style>
