---
import path from "node:path";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import PostMetadata from "@components/PostMeta.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import { getMomentUrlBySlug, getDir } from "@utils/url-utils";
import { getMomentSlug, getSortedMoments } from "@utils/moment-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig } from "@/config";

export async function getStaticPaths() {
	const entries = await getSortedMoments();
	return entries.map((entry) => ({
		params: { slug: getMomentSlug(entry) },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const moments = await getSortedMoments();
const currentSlug = getMomentSlug(entry);
const currentIdx = moments.findIndex((item) => getMomentSlug(item) === currentSlug);
const newerMoment = currentIdx > 0 ? moments[currentIdx - 1] : null;
const olderMoment =
	currentIdx >= 0 && currentIdx < moments.length - 1
		? moments[currentIdx + 1]
		: null;
---

<MainGridLayout
	title={entry.data.title}
	description={entry.data.description || entry.data.title}
	lang={entry.data.lang}
	setOGTypeArticle={true}
	headings={headings}
>
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
		<div
			id="moment-container"
			class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full border border-[var(--line-color)]"
		>
			<div class="flex items-center gap-2 text-[var(--primary)] text-sm font-semibold mb-3 onload-animation">
				<Icon name="material-symbols:bolt-rounded" class="text-[1.1rem]" />
				{"\u52a8\u6001"}
			</div>

			<h1
				class="onload-animation transition w-full block font-bold mb-3 text-3xl md:text-[2.25rem]/[2.75rem] text-black/90 dark:text-white/90"
			>
				{entry.data.title}
			</h1>

			<div class="onload-animation">
				<PostMetadata
					class="mb-5"
					published={entry.data.published}
					updated={entry.data.updated}
					tags={entry.data.tags}
					category={null}
				/>
				{!entry.data.image && (
					<div class="border-[var(--line-divider)] border-dashed border-b-[1px] mb-5"></div>
				)}
			</div>

			{entry.data.image && (
				<ImageWrapper
					id="moment-cover"
					src={entry.data.image}
					basePath={path.join("content/posts/", getDir(entry.id))}
					class="mb-8 rounded-xl banner-container onload-animation"
					alt={`Cover image of moment: ${entry.data.title}`}
				/>
			)}

			<Markdown class="mb-6 markdown-content onload-animation">
				<Content />
			</Markdown>

			{licenseConfig.enable && (
				<License
					title={entry.data.title}
					slug={`moments/${currentSlug}`}
					pubDate={entry.data.published}
					class="mb-6 rounded-xl license-container onload-animation"
				/>
			)}
		</div>
	</div>

	<div class="flex flex-col md:flex-row justify-between mb-4 gap-4 overflow-hidden w-full">
		<a
			href={olderMoment ? getMomentUrlBySlug(getMomentSlug(olderMoment)) : "#"}
			class:list={[
				"w-full font-bold overflow-hidden active:scale-95",
				{ "pointer-events-none": !olderMoment },
			]}
		>
			{
				olderMoment && (
					<div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-start gap-4">
						<Icon
							name="material-symbols:chevron-left-rounded"
							class="text-[2rem] text-[var(--primary)]"
						/>
						<div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
							{olderMoment.data.title}
						</div>
					</div>
				)
			}
		</a>

		<a
			href={newerMoment ? getMomentUrlBySlug(getMomentSlug(newerMoment)) : "#"}
			class:list={[
				"w-full font-bold overflow-hidden active:scale-95",
				{ "pointer-events-none": !newerMoment },
			]}
		>
			{
				newerMoment && (
					<div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-end gap-4">
						<div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
							{newerMoment.data.title}
						</div>
						<Icon
							name="material-symbols:chevron-right-rounded"
							class="text-[2rem] text-[var(--primary)]"
						/>
					</div>
				)
			}
		</a>
	</div>
</MainGridLayout>
