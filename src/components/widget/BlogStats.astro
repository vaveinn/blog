---
import { siteConfig } from "@/config";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import WidgetLayout from "./WidgetLayout.astro";

const posts = await getCollection("posts", ({ data }) =>
	import.meta.env.PROD ? data.draft !== true : true,
);

function stripMarkdown(markdown: string): string {
	return markdown
		.replace(/```[\s\S]*?```/g, " ")
		.replace(/`[^`]*`/g, " ")
		.replace(/!\[[^\]]*]\([^)]*\)/g, " ")
		.replace(/\[[^\]]*]\([^)]*\)/g, " ")
		.replace(/<[^>]+>/g, " ")
		.replace(/[>#*_~\-]/g, " ")
		.replace(/\s+/g, " ")
		.trim();
}

function countPostWords(markdown: string): number {
	const plainText = stripMarkdown(markdown);
	const cjkChars = plainText.match(/[\u3400-\u9fff]/g) ?? [];
	const latinWords =
		plainText
			.replace(/[\u3400-\u9fff]/g, " ")
			.match(/[A-Za-z0-9]+(?:['-][A-Za-z0-9]+)*/g) ?? [];
	return cjkChars.length + latinWords.length;
}

const postCount = posts.length;
const totalWords = posts.reduce((sum, post) => sum + countPostWords(post.body), 0);

function buildCounterNamespace(title: string): string {
	const slug = title
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, "-")
		.replace(/^-+|-+$/g, "");
	return `fuwari-${slug || "blog"}`;
}

const counterNamespace = buildCounterNamespace(siteConfig.title);
const counterKey = "site-visits";
---

<WidgetLayout id="blog-stats" name="站点数据" class="onload-animation" style="animation-delay: 120ms">
	<div
		id="blog-stats-data"
		class="stats-list"
		data-counter-namespace={counterNamespace}
		data-counter-key={counterKey}
	>
		<div class="stats-item">
			<div class="stats-label">
				<Icon name="fa6-solid:file-lines" class="stats-icon" />
				文章数量
			</div>
			<div class="stats-value">{postCount.toLocaleString("zh-CN")}</div>
		</div>

		<div class="stats-item">
			<div class="stats-label">
				<Icon name="fa6-solid:font" class="stats-icon" />
				总字数
			</div>
			<div class="stats-value">{totalWords.toLocaleString("zh-CN")}</div>
		</div>

		<div class="stats-item">
			<div class="stats-label">
				<Icon name="fa6-solid:chart-column" class="stats-icon" />
				网站访问量
			</div>
			<div id="site-visit-count" class="stats-value">Loading...</div>
		</div>

		<div class="stats-item">
			<div class="stats-label">
				<Icon name="fa6-solid:globe" class="stats-icon" />
				当前 IP
			</div>
			<div id="site-visitor-ip" class="stats-value">Loading...</div>
		</div>
	</div>
</WidgetLayout>

<style>
	.stats-list {
		display: grid;
		gap: 0.55rem;
	}

	.stats-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 0.7rem;
		border-radius: 0.75rem;
		background: var(--btn-regular-bg);
		border: 1px solid var(--line-color);
	}

	.stats-label {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: rgb(0 0 0 / 0.72);
		font-size: 0.9rem;
	}

	.stats-value {
		color: var(--primary);
		font-weight: 700;
		font-size: 0.9rem;
		text-align: right;
		word-break: break-all;
	}

	.stats-icon {
		font-size: 1rem;
		color: var(--primary);
	}

	:global(.dark) .stats-label {
		color: rgb(255 255 255 / 0.74);
	}
</style>

<script is:inline>
	function setText(el, value) {
		if (el) {
			el.textContent = value;
		}
	}

	async function fetchJson(endpoint) {
		const response = await fetch(endpoint, { cache: "no-store" });
		if (!response.ok) {
			throw new Error(`request failed: ${response.status}`);
		}
		return response.json();
	}

	async function loadVisitCount(namespace, key, visitElement) {
		const visitEndpoints = [
			`https://api.counterapi.dev/v1/${namespace}/${key}/up`,
			`https://api.countapi.xyz/hit/${namespace}/${key}`,
		];

		for (const endpoint of visitEndpoints) {
			try {
				const data = await fetchJson(endpoint);
				const value =
					typeof data?.count === "number"
						? data.count
						: typeof data?.value === "number"
							? data.value
							: NaN;
				if (!Number.isNaN(value)) {
					setText(visitElement, new Intl.NumberFormat("zh-CN").format(value));
					return;
				}
			} catch {
				// try next endpoint
			}
		}

		setText(visitElement, "N/A");
	}

	async function loadVisitorIp(ipElement) {
		const ipEndpoints = [
			"https://api64.ipify.org?format=json",
			"https://api.ipify.org?format=json",
			"https://api.ip.sb/jsonip",
		];

		for (const endpoint of ipEndpoints) {
			try {
				const data = await fetchJson(endpoint);
				if (typeof data?.ip === "string" && data.ip.length > 0) {
					setText(ipElement, data.ip);
					return;
				}
			} catch {
				// try next endpoint
			}
		}

		setText(ipElement, "N/A");
	}

	function initBlogStats() {
		const dataElement = document.getElementById("blog-stats-data");
		const visitElement = document.getElementById("site-visit-count");
		const ipElement = document.getElementById("site-visitor-ip");
		if (!dataElement || !visitElement || !ipElement) return;

		const namespace = dataElement.dataset.counterNamespace || "fuwari-blog";
		const key = dataElement.dataset.counterKey || "site-visits";

		loadVisitCount(namespace, key, visitElement);
		loadVisitorIp(ipElement);
	}

	if (!window.__blogStatsInitialized) {
		window.__blogStatsInitialized = true;

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", initBlogStats);
		} else {
			initBlogStats();
		}

		document.addEventListener("swup:contentReplaced", initBlogStats);
	}
</script>
